# Configuración del servidor
PORT=3000

# CORS - Lista de orígenes permitidos separados por coma
# Ejemplos:
# - Desarrollo: http://localhost:4200
# - Producción: https://tu-frontend.com,https://www.tu-frontend.com
# - Permitir todos: * (NO recomendado en producción)
CORS_ORIGIN=https://tu-dominio-frontend.com,https://www.tu-dominio-frontend.com

# Node Environment
NODE_ENV=production

# Perenual API (GRATIS - 300 requests/día)
# Obtén tu key gratis en: https://perenual.com/docs/api
PERENUAL_API_KEY=tu-key-aqui

# Pexels API (GRATIS - 200 requests/hora)
# Obtén tu key gratis en: https://www.pexels.com/api/
PEXELS_API_KEY=tu-key-aqui

# Cache settings
CACHE_TTL_HOURS=24
